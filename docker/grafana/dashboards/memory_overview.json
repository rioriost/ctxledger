          "rawSql": "SELECT\n  COALESCE(memory_summary_count, 0) AS memory_summary_count,\n  COALESCE(memory_summary_membership_count, 0) AS memory_summary_membership_count,\n  CASE\n    WHEN COALESCE(memory_summary_count, 0) = 0 THEN 'No canonical summaries built yet'\n    WHEN COALESCE(memory_summary_membership_count, 0) = 0 THEN 'Summaries exist but memberships are absent'\n    ELSE 'Canonical summary layer present'\n  END AS summary_layer_reading\nFROM observability.memory_overview;",
