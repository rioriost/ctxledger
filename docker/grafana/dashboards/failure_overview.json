          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  failure_scope,\n  failure_type,\n  failure_status,\n  COALESCE(target_path, '')::text AS target_path,\n  COALESCE(NULLIF(error_code, ''), '')::text AS error_code,\n  COALESCE(error_message, '')::text AS error_message,\n  retry_count,\n  occurred_at,\n  resolved_at,\n  COALESCE(attempt_id::text, '') AS attempt_id\nFROM observability.failure_overview\nORDER BY occurred_at DESC\nLIMIT 50;",
