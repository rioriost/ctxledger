          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  vrs.verify_reports_created_last_24h,\n  frs.failures_created_last_24h,\n  CASE\n    WHEN vrs.verify_reports_created_last_24h = 0 AND frs.failures_created_last_24h = 0 THEN 'no recent verify or failure activity'\n    WHEN frs.failures_created_last_24h > 0 AND vrs.verify_reports_created_last_24h = 0 THEN 'failure activity without recent verify reports'\n    WHEN frs.failures_created_last_24h > 0 THEN 'recent failures present alongside verify activity'\n    ELSE 'verify activity present without recent failure spike'\n  END AS verify_failure_reading\nFROM observability.failure_recent_summary AS frs\nCROSS JOIN observability.runtime_recent_activity_summary AS vrs;",
          "refId": "A"
        }
      ],
      "title": "Verify / Failure Correlation Reading",
      "type": "table"
