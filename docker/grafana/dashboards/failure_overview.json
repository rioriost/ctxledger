          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  failure_scope,\n  failure_type,\n  failure_count,\n  latest_occurred_at\nFROM (\n  SELECT\n    failure_scope,\n    failure_type,\n    COUNT(*)::bigint AS failure_count,\n    MAX(occurred_at) AS latest_occurred_at\n  FROM failures\n  WHERE occurred_at >= now() - interval '7 days'\n  GROUP BY failure_scope, failure_type\n  UNION ALL\n  SELECT\n    'none'::text AS failure_scope,\n    'no recent repeated failures'::text AS failure_type,\n    0::bigint AS failure_count,\n    NULL::timestamptz AS latest_occurred_at\n  WHERE NOT EXISTS (\n    SELECT 1\n    FROM failures\n    WHERE occurred_at >= now() - interval '7 days'\n  )\n) AS repeated_failure_signals\nORDER BY failure_count DESC, latest_occurred_at DESC NULLS LAST\nLIMIT 20;",
          "refId": "A"
        }
      ],
      "title": "Repeated Failure Signals (7d)",
      "type": "table"
