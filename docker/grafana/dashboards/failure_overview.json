          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time, \"Failures\"\nFROM (\n  SELECT date_trunc('hour', occurred_at) AS time, COUNT(*)::bigint AS \"Failures\"\n  FROM failures\n  WHERE occurred_at IS NOT NULL\n  GROUP BY 1\n  UNION ALL\n  SELECT now() AS time, 0::bigint AS \"Failures\"\n  WHERE NOT EXISTS (\n    SELECT 1\n    FROM failures\n    WHERE occurred_at IS NOT NULL\n  )\n) AS failure_timeline\nORDER BY 1;",
          "refId": "A"
        }
      ],
      "title": "Failure Activity Timeline",
      "type": "timeseries"
