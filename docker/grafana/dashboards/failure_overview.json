          "rawQuery": true,
          "rawSql": "SELECT \"Status\", \"Failures\"\nFROM (\n  SELECT initcap(status) AS \"Status\", COUNT(*)::bigint AS \"Failures\"\n  FROM failures\n  GROUP BY status\n  UNION ALL\n  SELECT 'No failures'::text AS \"Status\", 0::bigint AS \"Failures\"\n  WHERE NOT EXISTS (\n    SELECT 1\n    FROM failures\n  )\n) AS failure_status_distribution\nORDER BY \"Status\" ASC;",
          "refId": "A"
