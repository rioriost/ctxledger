          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  failure_id,\n  failure_scope,\n  failure_type,\n  summary,\n  status,\n  workflow_instance_id,\n  attempt_id,\n  occurred_at\nFROM (\n  SELECT\n    failure_id::text AS failure_id,\n    failure_scope,\n    failure_type,\n    summary,\n    status,\n    COALESCE(workflow_instance_id::text, '') AS workflow_instance_id,\n    COALESCE(attempt_id::text, '') AS attempt_id,\n    occurred_at\n  FROM failures\n  UNION ALL\n  SELECT\n    ''::text AS failure_id,\n    'none'::text AS failure_scope,\n    'no recent failures'::text AS failure_type,\n    'No failure rows recorded yet'::text AS summary,\n    'clear'::text AS status,\n    ''::text AS workflow_instance_id,\n    ''::text AS attempt_id,\n    NULL::timestamptz AS occurred_at\n  WHERE NOT EXISTS (\n    SELECT 1\n    FROM failures\n  )\n) AS recent_failure_triage\nORDER BY occurred_at DESC NULLS LAST\nLIMIT 25;",
          "refId": "A"
        }
