          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  failures_created_last_24h,\n  failures_created_last_7d,\n  repeated_failure_groups_last_7d,\n  CASE\n    WHEN failures_created_last_24h = 0 AND failures_created_last_7d = 0 THEN 'no recent failure activity'\n    WHEN repeated_failure_groups_last_7d >= 3 THEN 'failure pressure needs review'\n    WHEN failures_created_last_24h > 0 THEN 'recent failure activity present'\n    ELSE 'historical failure activity present'\n  END AS failure_reading\nFROM observability.failure_recent_summary;",
          "refId": "A"
        }
      ],
      "title": "Failure Pressure Reading",
      "type": "table"
