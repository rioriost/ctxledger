# Example environment for the default local Docker stack.

CTXLEDGER_SMALL_AUTH_TOKEN=replace-with-a-generated-strong-secret
OPENAI_API_KEY=replace-with-your-openai-api-key

CTXLEDGER_GRAFANA_ADMIN_USER=admin
CTXLEDGER_GRAFANA_ADMIN_PASSWORD=replace-with-a-generated-strong-password
CTXLEDGER_GRAFANA_POSTGRES_USER=ctxledger_grafana
CTXLEDGER_GRAFANA_POSTGRES_PASSWORD=replace-with-a-generated-strong-password
CTXLEDGER_GRAFANA_POSTGRES_DB=ctxledger
CTXLEDGER_GRAFANA_POSTGRES_HOST=postgres:5432
CTXLEDGER_GRAFANA_POSTGRES_SSLMODE=disable

CTXLEDGER_GRAFANA_DOMAIN=localhost
CTXLEDGER_GRAFANA_ROOT_URL=http://localhost:3000
